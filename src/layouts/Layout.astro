---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Real-time infrastructure status for B+W Engineering web services." } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": description,
  "url": "https://status.bwengr.com",
  "isPartOf": {
    "@type": "WebSite",
    "name": "B+W Engineering and Design",
    "url": "https://bwengr.com"
  },
  "about": {
    "@type": "Organization",
    "name": "B+W Engineering and Design",
    "url": "https://bwengr.com"
  }
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class="bg-[#0a0a0f] text-white min-h-screen font-sans antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

  :root {
    --green: #22c55e;
    --yellow: #eab308;
    --red: #ef4444;
    --blue: #3b82f6;
    --charcoal: #1a1a2e;
    --light: #f8fafc;
    --bw-accent: #3b82f6;
  }

  * {
    box-sizing: border-box;
  }

  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    background: #0a0a0f;
    color: #f8fafc;
  }
</style>