---
import Layout from '../layouts/Layout.astro';
import statusData from '../data/status.json';

interface Incident {
  date: string;
  resolved?: string;
  title: string;
  description?: string;
}

interface StatusData {
  lastChecked: string;
  lastUpdated: string;
  services: {
    name: string;
    url: string;
    description: string;
    status: "operational" | "degraded" | "down";
    responseTime: number;
    uptime30d: number;
    httpCode: number;
  }[];
  incidents: Incident[] | null;
}

const typedStatus = statusData as StatusData;

const schema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "B+W Engineering System Status",
  "description": "Real-time infrastructure status for B+W Engineering web services including bwengr.com, drainageplans.la, gradingplans.la, and civilengineer.la.",
  "url": "https://status.bwengr.com",
  "isPartOf": {
    "@type": "WebSite",
    "name": "B+W Engineering and Design",
    "url": "https://bwengr.com"
  },
  "about": {
    "@type": "Organization",
    "name": "B+W Engineering and Design",
    "url": "https://bwengr.com"
  }
};

function getStatusColor(status: string) {
  switch (status) {
    case "operational": return "#22c55e";
    case "degraded": return "#eab308";
    case "down": return "#ef4444";
    default: return "#6b7280";
  }
}

function getOverallStatus(services: StatusData["services"]) {
  if (services.some(s => s.status === "down")) return "down";
  if (services.some(s => s.status === "degraded")) return "degraded";
  if (services.every(s => s.status === "operational")) return "operational";
  return "unknown";
}

const overallStatus = getOverallStatus(typedStatus.services);
const overallColor = getStatusColor(overallStatus);

const statusLabel = overallStatus === "operational" ? "All Systems Operational" :
                    overallStatus === "degraded" ? "Partial Degradation" :
                    overallStatus === "down" ? "Service Disruption" : "Status Unknown";

const incidents = typedStatus.incidents;
const lastIncident = incidents && incidents.length > 0
  ? [...incidents].sort((a, b) => new Date(b.resolved || b.date).getTime() - new Date(a.resolved || a.date).getTime())[0]
  : null;

const daysSinceIncident = lastIncident
  ? Math.floor((Date.now() - new Date(lastIncident.resolved || lastIncident.date).getTime()) / (1000 * 60 * 60 * 24))
  : null;

const uptimeBars = statusData.services.map(service => ({
  name: service.name,
  uptime: service.uptime30d,
  color: service.uptime30d >= 99 ? "#22c55e" : service.uptime30d >= 95 ? "#eab308" : "#ef4444"
}));
---

<Layout title="B+W Engineering System Status" description="Real-time infrastructure status for B+W Engineering web services. Monitor availability of bwengr.com, drainageplans.la, gradingplans.la, and civilengineer.la.">
  <a href="#main-content" class="skip-link">Skip to main content</a>
  <div class="container" id="main-content">
    <!-- Header -->
    <header class="header">
      <div class="status-badge" role="status" aria-live="polite">
        <span class="dot" style={`background: ${overallColor}`}></span>
        <span class="badge-text" style={`color: ${overallColor}`}>{statusLabel}</span>
      </div>
      <h1>B+W Engineering Status</h1>
      <p class="subtitle">Real-time infrastructure status for our web services. Monitor availability and performance across all B+W Engineering platforms.</p>
      <p class="last-updated">
        <span class="live-dot" style={`background: ${overallColor}`}></span>
        Checks every 5 minutes via <a href="https://github.com/bwengr/bwengr-status/actions" target="_blank" rel="noopener" class="hover:underline">GitHub Actions</a>
        <br />
        <time datetime={statusData.lastChecked || statusData.lastUpdated}>
          Last checked: {new Date(statusData.lastChecked || statusData.lastUpdated).toLocaleString('en-US', { timeZone: 'America/Los_Angeles' })} PST
        </time>
      </p>
    </header>

    {daysSinceIncident !== null && daysSinceIncident > 0 && (
      <div class="uptime-banner" role="status" aria-live="polite">
        <span class="uptime-days">{daysSinceIncident}</span> days uninterrupted
      </div>
    )}

    <!-- Uptime Chart -->
    <div class="chart-section">
      <h2>30-Day Uptime</h2>
      <div class="uptime-chart" role="img" aria-label="Uptime percentages for all monitored services">
        {uptimeBars.map((service) => (
          <div class="chart-row">
            <span class="chart-label">{service.name}</span>
            <div class="chart-bar-container" aria-hidden="true">
              <div class="chart-bar" style={`width: ${service.uptime}%; background: ${service.color}`}></div>
            </div>
            <span class="chart-value">{service.uptime}%</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Services Grid -->
    <div class="services-grid" role="list">
      {statusData.services.map((service) => (
        <a href={service.url} target="_blank" rel="noopener noreferrer" class="service-card" role="listitem" aria-label={`${service.name}: ${service.status}. ${service.description}. Response time: ${service.responseTime}ms. Uptime: ${service.uptime30d}%`}>
          <div class="service-header">
            <h3>{service.name}</h3>
            <div class="service-status">
              <span class="status-dot" style={`background: ${getStatusColor(service.status)}`} aria-hidden="true"></span>
              <span class="status-label" style={`color: ${getStatusColor(service.status)}`}>{service.status}</span>
            </div>
          </div>
          <p class="service-description">{service.description}</p>
          <div class="service-metrics">
            <span class="metric">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              {service.responseTime}ms avg response
            </span>
            <span class="metric">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              {service.uptime30d}% uptime (30 days)
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- RSS Link -->
    <div class="rss-link">
      <a href="/rss.xml" target="_blank" rel="noopener" aria-label="Subscribe to status updates via RSS feed">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
        </svg>
        Subscribe to Status Updates (RSS)
      </a>
    </div>

    <!-- Infrastructure Info -->
    <div class="infrastructure-section">
      <h2>Infrastructure</h2>
      <div class="infra-grid">
        <div class="infra-item">
          <div class="infra-icon" style="color: #3b82f6">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div>
            <p class="infra-title">GitHub Actions</p>
            <p class="infra-desc">Monitors every 5 minutes</p>
          </div>
        </div>
        <div class="infra-item">
          <div class="infra-icon" style="color: #22c55e">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <p class="infra-title">Cloudflare Pages</p>
            <p class="infra-desc">Edge deployment, LA region</p>
          </div>
        </div>
        <div class="infra-item">
          <div class="infra-icon" style="color: #a855f7">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
            </svg>
          </div>
          <div>
            <p class="infra-title">GitHub Repository</p>
            <p class="infra-desc">Open source status data</p>
          </div>
        </div>
        <div class="infra-item">
          <div class="infra-icon" style="color: #eab308">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <p class="infra-title">5-Minute Intervals</p>
            <p class="infra-desc">288 checks per day</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Footer -->
    <footer class="footer">
      <p>Need to reach us? Contact <a href="mailto:info@bwengr.com">info@bwengr.com</a> or call <a href="tel:+13237393913" aria-label="Call B+W Engineering at 323-739-3913">323-739-3913</a></p>
      <p>Part of <a href="https://bwengr.com" target="_blank" rel="noopener">B+W Engineering and Design</a></p>
    </footer>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
</Layout>

<style>
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background: #22c55e;
    color: white;
    padding: 8px 16px;
    z-index: 100;
    text-decoration: none;
    font-weight: 500;
  }

  .skip-link:focus {
    top: 0;
  }

  .container {
    max-width: 768px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }

  .header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .badge-text {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  h1 {
    font-size: 2rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .subtitle {
    color: #9ca3af;
    max-width: 28rem;
    margin: 0 auto 1rem;
    line-height: 1.6;
  }

  .last-updated {
    font-size: 0.75rem;
    color: #6b7280;
    line-height: 1.8;
  }

  .live-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 6px;
    animation: blink 1s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .uptime-banner {
    background: linear-gradient(135deg, #1e1e2e 0%, #12121a 100%);
    border: 1px solid #22c55e;
    border-radius: 0.75rem;
    padding: 1rem 1.5rem;
    text-align: center;
    margin-bottom: 2rem;
    color: #22c55e;
    font-size: 1rem;
    font-weight: 500;
  }

  .uptime-banner .uptime-days {
    font-size: 1.5rem;
    font-weight: 700;
  }

  .chart-section {
    background: #12121a;
    border: 1px solid #1e1e2e;
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .chart-section h2 {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 1rem;
  }

  .uptime-chart {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .chart-row {
    display: grid;
    grid-template-columns: 140px 1fr 50px;
    align-items: center;
    gap: 0.75rem;
  }

  .chart-label {
    font-size: 0.75rem;
    color: #9ca3af;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .chart-bar-container {
    height: 8px;
    background: #1e1e2e;
    border-radius: 4px;
    overflow: hidden;
  }

  .chart-bar {
    height: 100%;
    border-radius: 4px;
    transition: width 0.5s ease;
  }

  .chart-value {
    font-size: 0.75rem;
    color: #6b7280;
    text-align: right;
  }

  .services-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .service-card {
    display: block;
    background: #12121a;
    border: 1px solid #1e1e2e;
    border-radius: 0.75rem;
    padding: 1.25rem;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .service-card:hover {
    border-color: #2a2a3a;
  }

  .service-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .service-header h3 {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    transition: color 0.2s;
  }

  .service-card:hover h3 {
    color: #3b82f6;
  }

  .service-status {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .status-label {
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
  }

  .service-description {
    font-size: 0.875rem;
    color: #9ca3af;
    margin-bottom: 0.75rem;
  }

  .service-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .metric {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    color: #6b7280;
  }

  .metric svg {
    flex-shrink: 0;
  }

  .rss-link {
    text-align: center;
    margin-bottom: 2rem;
  }

  .rss-link a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #eab308;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    background: #12121a;
    border: 1px solid #1e1e2e;
    border-radius: 0.75rem;
    transition: border-color 0.2s;
  }

  .rss-link a:hover {
    border-color: #eab308;
  }

  .infrastructure-section {
    background: #12121a;
    border: 1px solid #1e1e2e;
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 3rem;
  }

  .infrastructure-section h2 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 1rem;
  }

  .infra-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .infra-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .infra-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .infra-icon {
    width: 32px;
    height: 32px;
    border-radius: 0.5rem;
    background: #1e1e2e;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .infra-title {
    font-size: 0.875rem;
    font-weight: 500;
    color: #fff;
  }

  .infra-desc {
    font-size: 0.75rem;
    color: #6b7280;
  }

  .footer {
    text-align: center;
  }

  .footer p {
    font-size: 0.875rem;
    color: #9ca3af;
    margin-bottom: 0.5rem;
  }

  .footer a {
    color: #3b82f6;
    text-decoration: none;
  }

  .footer a:hover {
    text-decoration: underline;
  }

  .footer p:last-child {
    color: #4b5563;
  }

  .footer p:last-child a {
    color: #9ca3af;
    font-weight: 500;
  }

  .footer p:last-child a:hover {
    color: #fff;
  }
</style>